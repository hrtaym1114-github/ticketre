{
  "manifest_version": 3,
  "name": "チケトレ - チケット購入アシスタント",
  "version": "0.1.0",
  "description": "チケットぴあの先着発売を最速で完了するためのアシスタント。混雑突破・公演狙い撃ち・自動リトライ。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "alarms",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://ticket.pia.jp/*",
    "https://t.pia.jp/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ticket.pia.jp/*",
        "https://t.pia.jp/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}